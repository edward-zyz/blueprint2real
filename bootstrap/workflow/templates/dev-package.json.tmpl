{
  "name": "{{projectName}}-dev",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "{{projectName}} 开发过程事实源：state/* + AGENT_RUNBOOK + workflow.config.mjs。脚本由 blueprint2real skill bundle 提供。",
  "scripts": {
    "render:board": "DEV_ROOT=\"$PWD\" node {{skillBundlePath}}/scripts/render-board.mjs",
    "validate:state": "DEV_ROOT=\"$PWD\" node {{skillBundlePath}}/scripts/validate-state.mjs",
    "validate:config": "DEV_ROOT=\"$PWD\" node {{skillBundlePath}}/scripts/validate-config.mjs",
    "validate:pipeline": "DEV_ROOT=\"$PWD\" node {{skillBundlePath}}/scripts/validate-pipeline-status.mjs",
    "promote": "DEV_ROOT=\"$PWD\" node {{skillBundlePath}}/scripts/promote.mjs",
    "deps:graph": "DEV_ROOT=\"$PWD\" node {{skillBundlePath}}/scripts/render-dependencies.mjs",
    "verify:handoff": "DEV_ROOT=\"$PWD\" node {{skillBundlePath}}/scripts/verify-handoff.mjs",
    "lint:redlines": "DEV_ROOT=\"$PWD\" node {{skillBundlePath}}/scripts/lint-redlines.mjs",
    "init": "node {{skillBundlePath}}/scripts/init.mjs",
    "test": "cd {{skillBundlePath}} && npm test"
  }
}
